# Required: create this token with Telegram BotFather
TELEGRAM_BOT_TOKEN=replace_with_botfather_token

# Local default database. On Render with a persistent disk, use /data/exhibitledger.db
DB_PATH=./exhibitledger.db

# Default exhibition used when the command omits a code
DEFAULT_EXHIBITION=SHWEDAGON2024

# Required only when reseeding Shwe Dagon from MMK source PDFs into THB.
# Current Shwe Dagon test rate: 150 MMK = 1 THB.
SEED_MMK_TO_THB_RATE=0.006666666666666667

# Export folder
EXPORT_DIR=./exports

# Logging level
LOG_LEVEL=INFO

# Future Google Sheets integration placeholders
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_APPLICATION_CREDENTIALS=
SHEETS_MAPPING_FILE=./sheets_mapping.example.json
